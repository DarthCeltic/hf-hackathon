{
  "runner": "llama_server",
  "board": true,
  "benchmark_default": true,
  "framework": {
    "name": "llama.cpp-et",
    "runner": "llama_server",
    "source_artifact": "llama_cpp_source"
  },
  "artifacts_file": "../artifacts.json",
  "canonical_variant": "SmolVLM-256M-Instruct-Q8_0",
  "score": {
    "metric": "tokens_per_second",
    "label": "Decode tokens/s",
    "higher_is_better": true
  },
  "note": "SmolVLM-256M is a VLM (Idefics3 arch) but benchmarked here as text-only. The LLM backbone is SmolLM2-135M-Instruct (already proven on ET-SoC1). Vision capability via the mmproj projector is an additional feature not exercised by this benchmark.",
  "llama_server": {
    "source_artifact": "llama_cpp_source",
    "model_artifact": "smolvlm_256m_q8_gguf",
    "server_artifact": "llama_server",
    "workdir_artifact": "llama_cpp_build",
    "host": "127.0.0.1",
    "port": 18100,
    "device": "ET",
    "gpu_layers": 99,
    "ctx_size": 2048,
    "batch_size": 256,
    "ubatch_size": 128,
    "parallel": 1,
    "cache_ram_mib": 0,
    "ready_timeout_s": 120,
    "request_timeout_s": 240,
    "flash_attn": false,
    "api": "completion",
    "prompt": "Repeat this token sequence without commentary: OK OK OK OK OK OK OK OK OK OK",
    "max_tokens": 96,
    "temperature": 0,
    "ignore_eos": true,
    "min_completion_tokens": 32,
    "perplexity": {
      "enabled": true,
      "perplexity_artifact": "llama_perplexity",
      "corpus_artifact": "wikitext2_raw_test",
      "ctx_size": 128,
      "batch_size": 128,
      "ubatch_size": 128,
      "timeout_s": 240,
      "min_ppl": 1.0,
      "max_ppl": 1000.0,
      "chunks": 4
    }
  }
}
