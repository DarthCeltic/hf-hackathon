{
  "suite": "smoke",
  "primary_metric": "kernel_wait_s",
  "lower_is_better": true,
  "board": {
    "device": "soc1sim",
    "launcher_timeout_s": 600,
    "outer_timeout_s": 660,
    "comment": "Real silicon via PCIe on a self-hosted ET board runner.",
    "models": {
      "yolo": {
        "defines": [
          "-funroll-loops",
          "-fno-tree-loop-distribute-patterns",
          "-DNUM_HARTS=16",
          "-DACTIVE_HARTS=8u",
          "-DBENCH_THREAD0_ONLY=1"
        ]
      },
      "dncnn": {
        "defines": [
          "-fno-tree-loop-distribute-patterns",
          "-fno-strict-aliasing",
          "-DBENCH_THREAD0_ONLY=1",
          "-DDNCNN_CH=64u",
          "-DDNCNN_HIDDEN=18u",
          "-DDNCNN_IMG=64u",
          "-DDNCNN_REAL=1",
          "-DNUM_HARTS=16",
          "-DACTIVE_HARTS=8"
        ]
      }
    }
  },
  "ci_smoke": {
    "comment": "Sys-emu on GitHub runners is very slow; use 1 pass and longer launcher timeout in CI.",
    "launcher_timeout_s": 10800,
    "outer_timeout_s": 10900,
    "models": {
      "yolo": {
        "defines": [
          "-funroll-loops",
          "-fno-tree-loop-distribute-patterns",
          "-DNUM_HARTS=16",
          "-DACTIVE_HARTS=8u",
          "-DBENCH_THREAD0_ONLY=1"
        ]
      },
      "dncnn": {
        "defines": [
          "-fno-tree-loop-distribute-patterns",
          "-fno-strict-aliasing",
          "-DBENCH_THREAD0_ONLY=1",
          "-DDNCNN_CH=64u",
          "-DDNCNN_HIDDEN=18u",
          "-DDNCNN_IMG=64u",
          "-DDNCNN_REAL=1",
          "-DACTIVE_HARTS=1"
        ]
      }
    }
  },
  "models": {
    "yolo": {
      "reference_contract": ".github/ci/reference/yolo.json",
      "canonical_variant": "yolo_m30",
      "source": "ported_models/yolo/src/yolo_m30_argbuf.c",
      "bench_dir": "yolo-bench",
      "manifest": "yolo_variants.txt",
      "score": {
        "metric": "kernel_wait_s",
        "label": "Mean end-to-end latency",
        "higher_is_better": false,
        "baseline_variant": "yolo_m30"
      },
      "build": {
        "opt": "-Ofast",
        "defines": [
          "-funroll-loops",
          "-fno-tree-loop-distribute-patterns",
          "-DNUM_HARTS=16",
          "-DYOLO_USE_16HART=1"
        ]
      },
      "mem_size": "0x05000000",
      "region_size": "0x05000000",
      "file_loads": [
        {
          "address": "0x0",
          "paths": [
            "zero2m.bin",
            "common/zero2m.bin"
          ],
          "required": true
        },
        {
          "address": "0x02000000",
          "paths": ["yolo/weights_region.bin"],
          "required": true
        },
        {
          "address": "0x04A00000",
          "paths": ["yolo/coco_room_000139_raw_480x640x3_uint8_rgb.bin"],
          "required": true
        }
      ],
      "dump_size": "0x01D01000",
      "validation": {
        "kind": "yolo_real_image_detections",
        "image_count": 5,
        "min_image_count": 5,
        "reference_contract": ".github/ci/reference/yolo.json",
        "source_shape": [480, 640, 3]
      },
      "benchmark_cases": [
        {
          "name": "coco_room_000139",
          "file_loads": [
            {
              "address": "0x04A00000",
              "paths": ["yolo/coco_room_000139_raw_480x640x3_uint8_rgb.bin"],
              "required": true
            }
          ],
          "accuracy": {
            "kind": "yolo_reference_detections",
            "offset": "0x01D00000",
            "max_detections": 64,
            "reference_case": "coco_room_000139"
          }
        },
        {
          "name": "coco_cat_524280",
          "file_loads": [
            {
              "address": "0x04A00000",
              "paths": ["yolo/coco_cat_524280_raw_480x640x3_uint8_rgb.bin"],
              "required": true
            }
          ],
          "accuracy": {
            "kind": "yolo_reference_detections",
            "offset": "0x01D00000",
            "max_detections": 64,
            "reference_case": "coco_cat_524280"
          }
        },
        {
          "name": "coco_giraffes_296969",
          "file_loads": [
            {
              "address": "0x04A00000",
              "paths": ["yolo/coco_giraffes_296969_raw_480x640x3_uint8_rgb.bin"],
              "required": true
            }
          ],
          "accuracy": {
            "kind": "yolo_reference_detections",
            "offset": "0x01D00000",
            "max_detections": 64,
            "reference_case": "coco_giraffes_296969"
          }
        },
        {
          "name": "coco_elephants_445248",
          "file_loads": [
            {
              "address": "0x04A00000",
              "paths": ["yolo/coco_elephants_445248_raw_480x640x3_uint8_rgb.bin"],
              "required": true
            }
          ],
          "accuracy": {
            "kind": "yolo_reference_detections",
            "offset": "0x01D00000",
            "max_detections": 64,
            "reference_case": "coco_elephants_445248"
          }
        },
        {
          "name": "coco_baseball_043816",
          "file_loads": [
            {
              "address": "0x04A00000",
              "paths": ["yolo/coco_baseball_043816_raw_480x640x3_uint8_rgb.bin"],
              "required": true
            }
          ],
          "accuracy": {
            "kind": "yolo_reference_detections",
            "offset": "0x01D00000",
            "max_detections": 64,
            "reference_case": "coco_baseball_043816"
          }
        }
      ]
    },
    "dncnn": {
      "canonical_variant": "dncnn20l64",
      "source": "ported_models/dncnn/src/dncnn_gen_int8.c",
      "bench_dir": "dncnn-bench",
      "manifest": "dncnn_variants.txt",
      "score": {
        "metric": "kernel_wait_s",
        "label": "Denoise kernel wait (64x64 tile)",
        "higher_is_better": false,
        "baseline_variant": "dncnn20l64"
      },
      "build": {
        "opt": "-O3",
        "defines": [
          "-fno-tree-loop-distribute-patterns",
          "-fno-strict-aliasing",
          "-DBENCH_THREAD0_ONLY=1",
          "-DDNCNN_CH=64u",
          "-DDNCNN_HIDDEN=18u",
          "-DDNCNN_IMG=64u",
          "-DDNCNN_REAL=1",
          "-DACTIVE_HARTS=8"
        ]
      },
      "file_loads": [
        {
          "address": "0x0",
          "paths": ["zero2m.bin", "common/zero2m.bin"],
          "required": true
        },
        {
          "address": "0x2000",
          "paths": ["dncnn/dncnn20l64_input.bin"],
          "required": true
        },
        {
          "address": "0x14000",
          "paths": ["dncnn/dncnn20l64_weights.bin"],
          "required": true
        }
      ],
      "dump_magic": "0xD3C11003",
      "dump_size": "0x11000",
      "accuracy": {
        "kind": "uint8_npy",
        "offset": "0x10000",
        "shape": [64, 64],
        "max_abs": 2,
        "reference_path": "ported_models/dncnn/refs/dncnn20l64_reference.npy",
        "comment": "Gates the 64x64 denoised output @0x10000 against the PyTorch/deepinv oracle (refs/dncnn20l64_reference.npy, produced by scripts/gen_dncnn_oracle.py running deepinv.models.DnCNN on the pinned weights). Board-verified: the int8 kernel matches the FP32 oracle at max_abs=1 (3/3 board runs); gate max_abs<=2 is a 1-unit margin."
      }
    },
    "lfm25": {
      "config": "ported_models/llama_cpp_et/benchmarks/lfm25.json"
    },
    "llama32_1b": {
      "config": "ported_models/llama_cpp_et/benchmarks/llama32_1b.json"
