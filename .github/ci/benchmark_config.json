{
  "suite": "smoke",
  "primary_metric": "kernel_wait_s",
  "lower_is_better": true,
  "board": {
    "device": "soc1sim",
    "launcher_timeout_s": 600,
    "outer_timeout_s": 660,
    "comment": "Real silicon via PCIe on a self-hosted ET board runner.",
    "models": {
      "dncnn": {
        "defines": [
          "-fno-tree-loop-distribute-patterns",
          "-DNUM_HARTS=16",
          "-DACTIVE_HARTS=8",
          "-DBENCH_THREAD0_ONLY=1"
        ]
      },
      "yolo": {
        "defines": [
          "-DYOLO_PASSES=1",
          "-DYOLO_IMAGE_COUNT=4",
          "-DYOLO_PRELOADED_INPUTS=1",
          "-DNUM_HARTS=16",
          "-DACTIVE_HARTS=8",
          "-DBENCH_THREAD0_ONLY=1"
        ]
      },
      "whisper": {
        "defines": [
          "-DDEPTH_PASSES=1",
          "-DNUM_HARTS=16",
          "-DACTIVE_HARTS=8",
          "-DBENCH_THREAD0_ONLY=1"
        ]
      }
    }
  },
  "ci_smoke": {
    "comment": "Sys-emu on GitHub runners is very slow; use 1 pass and longer launcher timeout in CI.",
    "launcher_timeout_s": 10800,
    "outer_timeout_s": 10900,
    "models": {
      "dncnn": {
        "defines": [
          "-fno-tree-loop-distribute-patterns",
          "-DACTIVE_HARTS=1",
          "-DBENCH_THREAD0_ONLY=1"
        ]
      },
      "yolo": {
        "defines": [
          "-DYOLO_PASSES=1",
          "-DYOLO_IMAGE_COUNT=4",
          "-DYOLO_PRELOADED_INPUTS=1"
        ]
      },
      "whisper": {
        "defines": [
          "-DDEPTH_PASSES=1"
        ]
      }
    }
  },
  "models": {
    "dncnn": {
      "canonical_variant": "int8_tfma_8hart",
      "source": "ported_models/dncnn/src/dncnn3_tfma_int8.c",
      "bench_dir": "dncnn3-pmc",
      "manifest": "int8_tfma_variants.txt",
      "full_manifest": "int8_tfma_variants.txt",
      "build": {
        "opt": "-O3",
        "defines": [
          "-fno-tree-loop-distribute-patterns",
          "-DBENCH_THREAD0_ONLY=1"
        ]
      },
      "file_loads": [
        {
          "address": "0x0",
          "paths": [
            "zero2m.bin",
            "dncnn3-bench/zero2m.bin"
          ],
          "required": true
        },
        {
          "address": "0x2000",
          "paths": [
            "dncnn3_input.bin",
            "dncnn3-bench/dncnn3_input.bin"
          ],
          "required": true
        },
        {
          "address": "0x4000",
          "paths": [
            "dncnn3_weights.bin",
            "dncnn3-bench/dncnn3_weights.bin"
          ],
          "required": true
        }
      ],
      "dump_magic": "0xD3C11003",
      "dump_size": "0x12000",
      "accuracy": {
        "kind": "sha256",
        "offset": "0x10000",
        "count": 4096,
        "expected_sha256": "78aacbc3fb34efb8ffa5467b931291ec2bdf5e19564fc45fe97b5affbc893dc6"
      },
      "requires_dncnn_inputs": true
    },
    "yolo": {
      "canonical_variant": "y10_00_base",
      "source": "ported_models/yolo/src/yolo_vpu_argbuf.c",
      "bench_dir": "yolo-bench",
      "manifest": "yolo_10_variants.txt",
      "full_manifest": "yolo_100_variants.txt",
      "score": {
        "metric": "kernel_wait_per_image_s",
        "label": "Kernel wait/image",
        "higher_is_better": false
      },
      "build": {
        "opt": "-O3",
        "defines": [
          "-DYOLO_PASSES=1",
          "-DYOLO_IMAGE_COUNT=4",
          "-DYOLO_PRELOADED_INPUTS=1"
        ]
      },
      "file_loads": [
        {
          "address": "0x0",
          "paths": [
            "zero2m.bin",
            "dncnn3-bench/zero2m.bin"
          ],
          "required": true
        },
        {
          "address": "0x4000",
          "paths": ["yolo-bench/yolo_image_set_input_f32.bin"],
          "required": true
        },
        {
          "address": "0x200000",
          "paths": ["yolo-bench/yolo_image_set_weights_f32.bin"],
          "required": true
        }
      ],
      "dump_magic": "0x10500001",
      "dump_size": "0x364000",
      "validation": {
        "kind": "yolo_image_set",
        "image_count": 4
      },
      "accuracy": {
        "kind": "uint8_npy",
        "image_count": 4,
        "offset": "0x300000",
        "reference_path": "yolo-bench/yolo_image_set_output_u8.npy",
        "shape": [4, 80, 80, 16],
        "max_abs": 0
      },
      "requires_dncnn_inputs": false
    },
    "whisper": {
      "canonical_variant": "w10_00_base",
      "source": "ported_models/whisper/src/whisper_transformer_vpu_argbuf.c",
      "bench_dir": "whisper-bench",
      "manifest": "whisper_10_variants.txt",
      "full_manifest": "whisper_100_variants.txt",
      "build": {
        "opt": "-O3",
        "defines": [
          "-DDEPTH_PASSES=1"
        ]
      },
      "file_loads": [
        {
          "address": "0x0",
          "paths": [
            "zero2m.bin",
            "dncnn3-bench/zero2m.bin"
          ],
          "required": true
        }
      ],
      "dump_magic": "0x57485350",
      "accuracy": {
        "kind": "checksum",
        "expected_output_sum": 2097152
      },
      "requires_dncnn_inputs": false
    },
    "lfm25": {
      "config": "ported_models/llama_cpp_et/benchmarks/lfm25.json"
    },
    "llama32_1b": {
      "config": "ported_models/llama_cpp_et/benchmarks/llama32_1b.json"
    },
    "gemma3n_e2b": {
      "config": "ported_models/llama_cpp_et/benchmarks/gemma3n_e2b.json"
    },
    "tinyllama11b": {
